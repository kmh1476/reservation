# Create Google Apps Script code content
gas_content = """
/**
 * 구글 시트와 연동되는 백엔드 코드 (Code.gs)
 * 1. 구글 시트 -> 확장 프로그램 -> Apps Script에 복사하세요.
 * 2. 'Bookings'라는 이름의 시트 탭이 있어야 합니다.
 */

function doPost(e) {
  var lock = LockService.getScriptLock();
  lock.waitLock(10000); // 중복 예약 방지를 위해 10초간 잠금 대기
  
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName("Bookings");
    
    // 시트가 없으면 생성
    if (!sheet) {
      sheet = ss.insertSheet("Bookings");
      sheet.appendRow(["신청시간", "상담날짜", "시간대", "학생이름", "상담내용"]);
    }

    var data = JSON.parse(e.postData.contents);
    
    // 시트에 데이터 추가
    sheet.appendRow([
      new Date(), 
      data.date, 
      data.slot, 
      data.name, 
      data.memo
    ]);

    return ContentService.createTextOutput("Success").setMimeType(ContentService.MimeType.TEXT);
    
  } catch (f) {
    return ContentService.createTextOutput("Error: " + f.message).setMimeType(ContentService.MimeType.TEXT);
  } finally {
    lock.releaseLock();
  }
}
"""

